{
  "name": "fagord",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:prod-api": "FAGORD_RUST_API_DOMAIN=https://rust-api.fagord.no react-router dev",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "fmt": "oxfmt ./app",
    "fmt:check": "oxfmt --check ./app",
    "lint": "oxlint ./app",
    "test": "vitest run"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.3.0",
    "@headlessui/react": "2.2.10",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "@tanstack/react-table": "8.21.3",
    "bootstrap": "5.3.8",
    "isbot": "5.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router": "8.2.0",
    "react-tagcloud": "2.3.3"
  },
  "devDependencies": {
    "@react-router/dev": "8.2.0",
    "@react-router/fs-routes": "8.2.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-tagcloud": "2.3.2",
    "@vitejs/plugin-react-swc": "4.3.1",
    "autoprefixer": "10.5.2",
    "happy-dom": "20.10.6",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "postcss": "8.5.16",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
