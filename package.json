{
  "name": "fagord",
  "private": true,
  "sideEffects": false,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:prod-api": "FAGORD_RUST_API_DOMAIN=https://rust-api.fagord.no react-router dev",
    "start": "react-router-serve build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "prettier": "prettier --write \"app/**/*.{ts,tsx,css}\"",
    "lint": "oxlint ./app",
    "test": "vitest run"
  },
  "dependencies": {
    "@headlessui/react": "2.2.10",
    "@react-router/node": "7.14.1",
    "@react-router/serve": "7.14.1",
    "@tanstack/react-table": "8.21.3",
    "bootstrap": "5.3.8",
    "isbot": "5.1.39",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.1",
    "react-tagcloud": "2.3.3"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.1",
    "@react-router/fs-routes": "7.14.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-tagcloud": "2.3.2",
    "@vitejs/plugin-react-swc": "4.3.0",
    "autoprefixer": "10.5.0",
    "happy-dom": "20.9.0",
    "oxlint": "1.61.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vite": "8.0.9",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}